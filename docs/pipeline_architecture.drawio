        <mxCell id="13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;arcSize=5;" value="&lt;b&gt;Step 1 — feature_engineering.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; Cyclic encode hour: sin(2&amp;pi;h/24), cos(2&amp;pi;h/24)&lt;br&gt;&amp;bull; Binary encode day_type: Weekday = 0, Weekend = 1&lt;br&gt;&amp;bull; MinMax normalise speed and volume&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;i&gt;(independently within each RoadCategory &amp;times; day_type subset)&lt;/i&gt;&lt;br&gt;&amp;bull; Feature vector: [ sin_h, cos_h, day_bin, speed_norm, vol_norm ]" vertex="1">
          <mxGeometry height="148" width="460" x="360" y="376" as="geometry" />
        </mxCell>
        <mxCell id="e8" edge="1" parent="1" source="12" style="edgeStyle=orthogonalEdgeStyle;html=1;" target="13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#888888;fontColor=#333333;fontSize=10;" value="&lt;b&gt;clustering/features/&lt;/b&gt;&lt;br&gt;features_&amp;lt;cat&amp;gt;_&amp;lt;day&amp;gt;.parquet &amp;nbsp;(&amp;times;12)&lt;br&gt;feature_metadata.json &amp;nbsp;(scaler params)" vertex="1">
          <mxGeometry height="60" width="255" x="890" y="396" as="geometry" />
        </mxCell>
        <mxCell id="e9" edge="1" parent="1" source="13" style="edgeStyle=orthogonalEdgeStyle;dashed=1;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="14">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;arcSize=5;" value="&lt;b&gt;Step 2 — run_clustering.py&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;bull; 12 independent runs: 6 RoadCategories &amp;times; 2 day_types&lt;br&gt;&amp;bull; K sweep K = 2..10, select optimal K by peak silhouette score&lt;br&gt;&amp;bull; K-Means fit (n_init = 10, random_state = 42)&lt;br&gt;&amp;bull; Merge clusters with size &amp;lt; 30 into nearest centroid&lt;br&gt;&amp;bull; Flag clusters: speed std &amp;gt; 15 km/h or IQR &amp;gt; 20 km/h&lt;br&gt;&amp;bull; Assign composite cluster_id &amp;nbsp;e.g. &amp;nbsp;&lt;i&gt;&amp;quot;EXP_WD_03&amp;quot;&lt;/i&gt;" vertex="1">
          <mxGeometry height="180" width="460" x="360" y="578" as="geometry" />
        </mxCell>
        <mxCell id="e10" edge="1" parent="1" source="13" style="edgeStyle=orthogonalEdgeStyle;html=1;" target="15">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;arcSize=5;" value="&lt;b&gt;Cluster Quality Criteria&lt;/b&gt;&lt;br&gt;&lt;br&gt;✓ Size &amp;ge; 30 records&lt;br&gt;✓ Speed std &amp;le; 15 km/h&lt;br&gt;✓ Speed IQR (P75&amp;minus;P25) &amp;le; 20 km/h&lt;br&gt;✓ Silhouette score &amp;ge; 0.3&lt;br&gt;&lt;br&gt;Fail size &amp;rarr; merge into nearest cluster&lt;br&gt;Fail spread &amp;rarr; flag for review (increase K)" vertex="1">
          <mxGeometry height="175" width="255" x="890" y="578" as="geometry" />
        </mxCell>
