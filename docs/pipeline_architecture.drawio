        <mxCell id="12" parent="1" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=0;" value="&lt;b&gt;data/input/traffic_hourly.csv&lt;/b&gt;&lt;br&gt;timestamp_hour (SGT) | LinkID | RoadCategory | hour (0&amp;ndash;23) | day_type | speed (km/h) | volume (veh/hr)" vertex="1">
          <mxGeometry height="62" width="460" x="360" y="258" as="geometry" />
        </mxCell>
        <mxCell id="e7" edge="1" parent="1" source="10" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.7;entryY=0;entryDx=0;entryDy=0;" target="12">
