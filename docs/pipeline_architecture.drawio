        </mxCell>
        <mxCell id="17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#888888;fontColor=#333333;fontSize=10;" value="&lt;b&gt;clustering/results/&lt;/b&gt;&lt;br&gt;assignments_&amp;lt;cat&amp;gt;_&amp;lt;day&amp;gt;.parquet &amp;nbsp;(&amp;times;12)&lt;br&gt;cluster_centers_&amp;lt;cat&amp;gt;_&amp;lt;day&amp;gt;.csv &amp;nbsp;(&amp;times;12)&lt;br&gt;elbow_silhouette_&amp;lt;cat&amp;gt;_&amp;lt;day&amp;gt;.csv &amp;nbsp;(&amp;times;12)" vertex="1">
