          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="18" parent="1" style="shape=note;size=18;whiteSpace=wrap;html=1;fillColor=#fffacd;strokeColor=#d6b656;fontSize=10;align=center;" value="&lt;b&gt;12 Independent&lt;br&gt;Clustering Runs&lt;/b&gt;&lt;br&gt;&lt;br&gt;6 RoadCategories&lt;br&gt;&amp;times; 2 day_types&lt;br&gt;&lt;br&gt;EXP &amp;nbsp;MJR &amp;nbsp;ART&lt;br&gt;MIN &amp;nbsp;LOC &amp;nbsp;ACC&lt;br&gt;&amp;times; Weekday / Weekend" vertex="1">
